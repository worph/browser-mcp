{
  "name": "browser-mcp",
  "version": "1.0.0",
  "description": "Containerized browser environment exposing Chromium interaction as MCP tools",
  "main": "dist/index.js",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/"
  },
  "keywords": [
    "mcp",
    "browser",
    "chromium",
    "playwright",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "playwright-core": "^1.48.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
